{
  "name": "forum-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:forum": "bun run --cwd apps/forum dev",
    "dev:frontpage": "bun run --cwd apps/frontpage dev",
    "dev:backend": "bun run --cwd packages/backend dev",
    "dev:convex": "bun run --cwd packages/convex dev",
    "dev": "bun run dev:forum & bun run dev:frontpage & bun run dev:backend & wait",
    "build": "bun run --cwd apps/forum build && bun run --cwd apps/frontpage build",
    "build:forum": "bun run --cwd apps/forum build",
    "build:frontpage": "bun run --cwd apps/frontpage build",
    "format": "bunx biome format --write .",
    "lint": "bunx biome lint .",
    "check": "bunx biome check --fix .",
    "ncu-all": "bunx npm-check-updates --workspaces -u"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.3"
  }
}
